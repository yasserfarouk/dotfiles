alias vi=vim
alias v=nvim
# always use the jdk in home if it exists. Works well on daiba
if [ -d $HOME/jdk ]; then
	JAVA_HOME=$HOME/jdk
	PATH=".:$JAVA_HOME/bin:$PATH"
fi
# uv manages Python - ensure it's in PATH
export PATH="$HOME/.local/bin:$PATH"
[ -x "$HOME/.linuxbrew/bin/brew" ] && eval "$($HOME/.linuxbrew/bin/brew shellenv)"
